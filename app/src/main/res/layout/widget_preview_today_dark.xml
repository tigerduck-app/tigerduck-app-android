<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C1E"
    android:padding="10dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="星期一"
        android:textColor="#F5F5F5"
        android:textSize="15sp"
        android:textStyle="bold"
        android:paddingBottom="6dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#4DA3FF"
        android:padding="6dp"
        android:layout_marginBottom="4dp">
        <LinearLayout android:layout_width="56dp" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3–4" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10:20–12:10" android:textColor="#E6E6E6" android:textSize="11sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:paddingLeft="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="資料結構" android:textColor="#FFFFFF" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="E2-106" android:textColor="#E6E6E6" android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#2C2C2E"
        android:padding="6dp"
        android:layout_marginBottom="4dp">
        <LinearLayout android:layout_width="56dp" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6–7" android:textColor="#F5F5F5" android:textSize="13sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="13:20–15:10" android:textColor="#8E8E93" android:textSize="11sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:paddingLeft="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="演算法" android:textColor="#F5F5F5" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="E2-308" android:textColor="#8E8E93" android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
